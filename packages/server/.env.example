# Server Environment Configuration
PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/grcopening?schema=public"

# Blocked personal domains for Employers (comma-separated)
AUTH_EMP_DOMAIN="gmail.com,yahoo.com,hotmail.com,outlook.com,aol.com"

# SMTP — Email delivery for OTP verification
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="GRC Openings"
