datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =====================================
// ENUMS
// =====================================
enum Role {
  ADMIN
  JOB_SEEKER
  EMPLOYER
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE
}

enum JobStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEWING
  REJECTED
  HIRED
  WITHDRAWN
}

enum ReportReason {
  SPAM
  MISLEADING
  INAPPROPRIATE
  OTHER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum NotificationType {
  // Admin → Employer or Seeker
  ACCOUNT_SUSPENDED
  ACCOUNT_BANNED
  ACCOUNT_REINSTATED
  COMPANY_VERIFICATION_REVOKED
  COMPANY_VERIFIED
  JOB_FORCE_CLOSED

  // Employer → Seeker (application status changes)
  APPLICATION_REVIEWING
  APPLICATION_INTERVIEWING
  APPLICATION_HIRED
  APPLICATION_REJECTED

  // System → Seeker (a job they applied to or saved was closed)
  JOB_CLOSED

  // System → Employer (new application received)
  NEW_APPLICATION

  // Admin broadcast to all users / specific roles
  ADMIN_BROADCAST
}

enum ResumeStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// =====================================
// MODELS
// =====================================

model User {
  id                     String     @id @default(uuid())
  email                  String     @unique
  clerkId                String?    @unique @map("clerk_id")
  passwordHash           String?
  emailVerified          Boolean    @default(false) @map("email_verified")
  role                   Role       @default(JOB_SEEKER)
  status                 UserStatus @default(ACTIVE)
  lastVerificationSentAt DateTime?  @map("last_verification_sent_at")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  // Relations
  seekerProfile      SeekerProfile?
  employerProfile    EmployerProfile?
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  notifications      Notification[]
  auditLogs          AuditLog[]

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at") // null = unused; non-null = already burned
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model SeekerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  firstName   String   @map("first_name")
  middleName  String?  @map("middle_name")
  lastName    String   @map("last_name")
  headline    String?
  phone       String?
  country     String?
  bio         String?
  resumeUrl   String?  @map("resume_url")
  location    String?
  linkedInUrl String?  @map("linked_in_url")
  avatarUrl   String?  @map("avatar_url")

  // Critical employment info (shared only when candidate opts in)
  openToShareCriticalInfo Boolean @default(false) @map("open_to_share_critical_info")
  ctcCurrency             String? @default("INR") @map("ctc_currency")
  currentCtc              String? @map("current_ctc")
  expectedCtc             String? @map("expected_ctc")
  noticePeriod            String? @map("notice_period")
  buybackOption           String? @map("buyback_option")
  reasonForChange         String? @map("reason_for_change")
  reasonForChangeOther    String? @map("reason_for_change_other")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          Skill[] // Implicit many-to-many
  applications    Application[]
  savedJobs       SavedJob[]
  workExperiences WorkExperience[]
  certifications  SeekerCertification[]
  jobReports      JobReport[]
  resumes         Resume[]
  educations      Education[]

  @@map("seeker_profiles")
}

model WorkExperience {
  id          String   @id @default(uuid())
  seekerId    String   @map("seeker_id")
  title       String
  company     String
  location    String?
  startDate   String   @map("start_date")
  endDate     String?  @map("end_date")
  current     Boolean  @default(false)
  description String?
  sortOrder   Int      @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@map("work_experiences")
}

model SeekerCertification {
  id        String   @id @default(uuid())
  seekerId  String   @map("seeker_id")
  name      String
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@map("seeker_certifications")
}

model EmployerProfile {
  id                       String   @id @default(uuid())
  userId                   String   @unique @map("user_id")
  companyName              String   @map("company_name")
  representativeFirstName  String?  @map("representative_first_name")
  representativeMiddleName String?  @map("representative_middle_name")
  representativeLastName   String?  @map("representative_last_name")
  industry                 String?
  companySize              String?  @map("company_size")
  description              String?
  tagline                  String?
  foundedYear              String?  @map("founded_year")
  website                  String?
  logoUrl                  String?  @map("logo_url")
  phone                    String?
  contactPhoneCode         String?  @map("contact_phone_code")
  contactName              String?  @map("contact_name")
  contactEmail             String?  @map("contact_email")
  address                  String?
  city                     String?
  state                    String?
  country                  String?
  countryCode              String?  @map("country_code")
  linkedInUrl              String?  @map("linked_in_url")
  twitterUrl               String?  @map("twitter_url")
  otherUrl                 String?  @map("other_url")
  isVerified               Boolean  @default(false) @map("is_verified")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("employer_profiles")
}

model Skill {
  id   String @id @default(uuid())
  name String @unique

  // Relations
  seekers SeekerProfile[] // Implicit many-to-many

  @@map("skills")
}

model Job {
  id                String    @id @default(uuid())
  employerId        String    @map("employer_id")
  title             String
  description       String
  location          String?
  workMode          WorkMode  @default(ON_SITE) @map("work_mode")
  status            JobStatus @default(DRAFT)
  deadline          DateTime? @map("deadline")
  category          String?
  jobType           String?   @map("job_type")
  seniority         String?
  experience        String?
  niceToHave        String?   @map("nice_to_have")
  currency          String?   @default("USD")
  undisclosedSalary Boolean   @default(false) @map("undisclosed_salary")
  adminNote         String?   @map("admin_note")
  salaryMin         Int?      @map("salary_min")
  salaryMax         Int?      @map("salary_max")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  employer       EmployerProfile    @relation(fields: [employerId], references: [id], onDelete: Cascade)
  certifications JobCertification[]
  applications   Application[]
  savedBySeekers SavedJob[]
  reports        JobReport[]

  @@index([status]) // Requested index
  @@index([status, deadline])
  @@map("jobs")
}

model JobCertification {
  id    String @id @default(uuid())
  jobId String @map("job_id")
  name  String

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_certifications")
}

model Application {
  id        String            @id @default(uuid())
  jobId     String            @map("job_id")
  seekerId  String            @map("seeker_id")
  status    ApplicationStatus @default(PENDING)
  notes     String?
  appliedAt DateTime          @default(now()) @map("applied_at")

  // Relations
  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@unique([seekerId, jobId])
  @@map("applications")
}

model JobReport {
  id          String       @id @default(uuid())
  jobId       String       @map("job_id")
  seekerId    String       @map("seeker_id")
  reason      ReportReason
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")

  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@map("job_reports")
}

model SavedJob {
  id       String   @id @default(uuid())
  jobId    String   @map("job_id")
  seekerId String   @map("seeker_id")
  savedAt  DateTime @default(now()) @map("saved_at")

  // Relations
  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  // Ensure a user can only save a specific job once
  @@unique([seekerId, jobId])
  @@map("saved_jobs")
}

// =====================================
// RESUME PARSING
// =====================================

model Resume {
  id           String       @id @default(uuid())
  seekerId     String       @map("seeker_id")
  originalName String       @map("original_name")
  filePath     String       @map("file_path")
  fileSize     Int          @map("file_size")
  mimeType     String       @default("application/pdf") @map("mime_type")
  status       ResumeStatus @default(PENDING)
  parsedData   Json?        @map("parsed_data")
  errorMessage String?      @map("error_message")
  retryCount   Int          @default(0) @map("retry_count")
  processedAt  DateTime?    @map("processed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@index([seekerId])
  @@index([status])
  @@map("resumes")
}

model Education {
  id          String   @id @default(uuid())
  seekerId    String   @map("seeker_id")
  institution String
  degree      String?
  field       String?
  gpa         String?
  startDate   String?  @map("start_date")
  endDate     String?  @map("end_date")
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id") // recipient User.id
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json? // { jobId?, applicationId?, jobTitle?, companyName?, seekerName? }
  expiresAt DateTime         @map("expires_at") // createdAt + 10 days
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([expiresAt]) // enables efficient TTL sweeps
  @@map("notifications")
}

// =====================================
// AUDIT LOGS
// =====================================

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String   // USER_DISABLED, JOB_CLOSED, COMPANY_VERIFIED, BROADCAST_SENT, etc.
  targetType String?  @map("target_type") // USER, JOB, COMPANY, BROADCAST
  targetId   String?  @map("target_id")
  metadata   Json?    // { reason, email, title, previousStatus, targetRole, recipientCount, … }
  createdAt  DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}
