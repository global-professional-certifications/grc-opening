datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ENUMS

enum Role {
  ADMIN
  JOB_SEEKER
  EMPLOYER
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEWING
  REJECTED
  HIRED
}

// =====================================
// MODELS
// =====================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  emailVerified Boolean  @default(false) @map("email_verified")
  role          Role     @default(JOB_SEEKER)
  lastVerificationSentAt DateTime? @map("last_verification_sent_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  seekerProfile       SeekerProfile?
  employerProfile     EmployerProfile?
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at") // null = unused; non-null = already burned
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model SeekerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  firstName    String   @map("first_name")
  middleName   String?  @map("middle_name")
  lastName     String   @map("last_name")
  headline     String?
  country      String?
  bio          String?
  resumeUrl    String?  @map("resume_url")
  location     String?
  linkedInUrl  String?  @map("linked_in_url")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills           Skill[]               // Implicit many-to-many
  applications     Application[]
  savedJobs        SavedJob[]
  workExperiences  WorkExperience[]
  certifications   SeekerCertification[]

  @@map("seeker_profiles")
}

model WorkExperience {
  id          String   @id @default(uuid())
  seekerId    String   @map("seeker_id")
  title       String
  company     String
  location    String?
  startDate   String   @map("start_date")
  endDate     String?  @map("end_date")
  current     Boolean  @default(false)
  description String?
  sortOrder   Int      @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@map("work_experiences")
}

model SeekerCertification {
  id        String   @id @default(uuid())
  seekerId  String   @map("seeker_id")
  name      String
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@map("seeker_certifications")
}

model EmployerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  companyName              String   @map("company_name")
  representativeFirstName  String   @map("representative_first_name")
  representativeMiddleName String?  @map("representative_middle_name")
  representativeLastName   String   @map("representative_last_name")
  industry           String?
  companySize        String?  @map("company_size")
  description        String?
  website            String?
  logoUrl            String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@map("employer_profiles")
}

model Skill {
  id   String @id @default(uuid())
  name String @unique

  // Relations
  seekers SeekerProfile[] // Implicit many-to-many

  @@map("skills")
}

model Job {
  id          String    @id @default(uuid())
  employerId  String    @map("employer_id")
  title       String
  description String
  location    String?
  workMode    WorkMode  @default(ON_SITE) @map("work_mode")
  status      JobStatus @default(DRAFT)
  salaryMin   Int?      @map("salary_min")
  salaryMax   Int?      @map("salary_max")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  employer       EmployerProfile    @relation(fields: [employerId], references: [id], onDelete: Cascade)
  certifications JobCertification[]
  applications   Application[]
  savedBySeekers SavedJob[]

  @@index([status]) // Requested index
  @@map("jobs")
}

model JobCertification {
  id    String @id @default(uuid())
  jobId String @map("job_id")
  name  String

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_certifications")
}

model Application {
  id        String            @id @default(uuid())
  jobId     String            @map("job_id")
  seekerId  String            @map("seeker_id")
  status    ApplicationStatus @default(PENDING)
  notes     String?
  appliedAt DateTime          @default(now()) @map("applied_at")

  // Relations
  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  @@index([seekerId, jobId]) // Requested index
  @@map("applications")
}

model SavedJob {
  id       String   @id @default(uuid())
  jobId    String   @map("job_id")
  seekerId String   @map("seeker_id")
  savedAt  DateTime @default(now()) @map("saved_at")

  // Relations
  job    Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)

  // Ensure a user can only save a specific job once
  @@unique([seekerId, jobId])
  @@map("saved_jobs")
}
